<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- ═══ TOPBAR ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_secondary"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@color/transparent"
            android:contentDescription="Retour"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nouvelle alerte SOS"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/status_sent_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@color/status_sent"
                android:layout_marginEnd="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="URGENCE"
                android:textColor="@color/status_sent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ═══ TYPE D'URGENCE ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TYPE D'URGENCE *"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <!-- Ligne 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Médicale -->
                <LinearLayout
                    android:id="@+id/type_medical"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_type_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="32dp"
                        android:background="#EF4444"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medicale"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blessure"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Sécurité -->
                <LinearLayout
                    android:id="@+id/type_security"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_type_card"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="32dp"
                        android:background="#F59E0B"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Securite"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Agression"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Ligne 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Incendie -->
                <LinearLayout
                    android:id="@+id/type_fire"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_type_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="32dp"
                        android:background="#F97316"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Incendie"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Feu, fumee"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Autre -->
                <LinearLayout
                    android:id="@+id/type_other"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_type_card"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="32dp"
                        android:background="#6B7280"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Autre"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Autre incident"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ GPS ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCALISATION GPS"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_gps_bar"
                android:padding="12dp"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/gps_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@color/gps_green"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tv_gps_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recherche de position..."
                    android:textColor="@color/gps_green"
                    android:textSize="12sp" />

                <ProgressBar
                    android:id="@+id/progress_gps"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/gps_green"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/iv_gps_refresh"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:background="@color/transparent"
                    android:contentDescription="Actualiser"
                    app:tint="@color/gps_green" />
            </LinearLayout>

            <!-- ═══ MESSAGE ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MESSAGE OPTIONNEL"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:hint="Message court (ex: personne evanouie a l'entree...)"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:maxLines="4" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══ BOUTON ENVOYER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_secondary"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_send_sos"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Envoyer l'alerte SOS"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/red_primary"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>