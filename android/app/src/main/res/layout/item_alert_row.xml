<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Point statut coloré -->
    <View
        android:id="@+id/view_status_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_circle"
        android:layout_marginEnd="14dp" />

    <!-- Infos alerte -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_alert_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Urgence médicale"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_alert_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="29 avr. 2026 à 15:53"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Badge statut -->
    <TextView
        android:id="@+id/tv_status_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENVOYÉE"
        android:textColor="@color/status_sent"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.04"
        android:background="@drawable/bg_badge_sent"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

</LinearLayout>