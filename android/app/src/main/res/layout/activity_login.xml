<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- ══ LOGO ══ -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo_sos"
            android:scaleType="fitCenter"
            android:contentDescription="SOS Campus"
            android:layout_marginBottom="16dp" />

        <!-- ══ TITRE ══ -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOS "
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campus"
                android:textColor="@color/red_primary"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══ SOUS-TITRE ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connectez-vous pour continuer"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="40dp" />

        <!-- ══ CHAMP EMAIL ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADRESSE EMAIL"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="exemple@ens-marrakech.ac.ma"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:layout_marginBottom="16dp" />

        <!-- ══ CHAMP MOT DE PASSE ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MOT DE PASSE"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Votre mot de passe"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:layout_marginBottom="12dp" />

        <!-- ══ MESSAGE ERREUR ══ -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/red_accent"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- ══ BARRE CHARGEMENT ══ -->
        <ProgressBar
            android:id="@+id/progress_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:indeterminateTint="@color/red_primary"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- ══ BOUTON SE CONNECTER ══ -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Se connecter"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/red_primary"
            android:stateListAnimator="@null"
            android:layout_marginBottom="32dp" />

        <!-- ══ SÉPARATEUR ══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_color"
            android:layout_marginBottom="20dp" />

        <!-- ══ FOOTER ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENS Marrakech — Departement Informatique"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alertes • Geolocalisees • Intervention Rapide"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>